{
  "rules": {
    "pub": {
      "$token": {
        "telegram": {
          ".read": true,
          ".write": "auth != null"
        },
        "uid": {
          ".read": true,
          ".write": "auth != null"
        },
        "verify": {
          ".read": true,
          ".write": true
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
