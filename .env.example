# TrigifyX — config template (safe to commit)
# Copy to .env and fill in real values. .env is gitignored.

# ===== Cloudflare Worker secrets =====
# Names must be alphanumeric + underscores only (no dots).
TELEGRAM_BOT_TOKEN=        # your @BotFather token
FIREBASE_DB_URL=           # https://<project>-default-rtdb.<region>.firebasedatabase.app
ALLOWED_ORIGINS=*          # comma-separated origins, or * for any

# ===== Frontend (public/js/env-injected.js) — already hardcoded, listed for reference =====
# Exact key names the code reads inside window.__ENV__:
#   apiBase    -> Worker URL (capture script posts submissions here)
#   scriptBase -> ""  (optional: where the capture script is hosted)
#   botToken   -> ""  (DEPRECATED: bot token is server-side in the Worker; not used)
