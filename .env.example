# TrigifyX — all configs template (safe to commit)
# Copy to .env and fill in real values. .env is gitignored.
# Use this when setting secrets in Netlify (frontend) and Cloudflare (Worker).

# ===== Cloudflare Worker secrets =====
# Names must be alphanumeric + underscores only (no dots).
TELEGRAM_BOT_TOKEN=        # your @BotFather token
FIREBASE_DB_URL=           # https://<project>-default-rtdb.<region>.firebasedatabase.app
ALLOWED_ORIGINS=*          # comma-separated origins, or * for any

# ===== Netlify frontend (read by public/js/env-injected.js) =====
TRIGIFYX_API_BASE=         # https://your-worker.<sub>.workers.dev
TRIGIFYX_SCRIPT_BASE=
TRIGIFYX_BOT_TOKEN=

# ===== Frontend Firebase config (already in public/js/firebase-init.js) =====
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
