# Render server environment (Render injects these at deploy time)
# Do NOT commit this file.

# Paste the FULL JSON from Firebase Console > Service Accounts > Generate new private key
FIREBASE_SA_KEY={"type":"service_account",...}

# Firebase Realtime Database base URL
FIREBASE_DB_URL=https://trigifyx-default-rtdb.asia-southeast1.firebasedatabase.app
