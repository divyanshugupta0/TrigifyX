# TrigifyX server environment variables
# Copy to .env and fill in. NEVER commit the real .env.

TELEGRAM_BOT_TOKEN=123456789:AAEyour_bot_token_here

# Port the server listens on
PORT=3000

# CORS: comma-separated list of allowed site origins. Use * to allow any.
ALLOWED_ORIGINS=*

# Firebase Admin credentials (server-side, trusted).
# Option A: path to a downloaded service-account JSON file.
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Option B: inline credentials (used if FIREBASE_SERVICE_ACCOUNT is empty).
# FIREBASE_PROJECT_ID=trigifyx
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@trigifyx.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Only set if you use a non-default Realtime Database URL.
# FIREBASE_DATABASE_URL=https://trigifyx-default-rtdb.asia-southeast1.firebasedatabase.app
